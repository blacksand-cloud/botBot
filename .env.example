# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS= # comma-separated chat IDs (optional). Leave empty to allow any chat.
TELEGRAM_MODE=polling # polling or webhook
TELEGRAM_WEBHOOK_SECRET= # optional HMAC secret to validate Telegram webhook (used via X-Telegram-Bot-Api-Secret-Token)

# BloomBot API
BLOOMBOT_API_BASE=https://solana.bloombot.app
BLOOMBOT_API_KEY=
BLOOMBOT_DRY_RUN=true

# Webhooks
PUBLIC_BASE_URL= # e.g. https://your-domain.com
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080
BLOOMBOT_WEBHOOK_PATH=/bloombot/webhook
BLOOMBOT_WEBHOOK_SECRET= # shared secret for validating BloomBot webhook HMAC (if supported)
TELEGRAM_WEBHOOK_PATH=/telegram/webhook

# Trading defaults
DEFAULT_SLIPPAGE_BPS=300
DEFAULT_PRIORITY_FEE_LAMPORTS=0

# Allowed tokens (comma-separated symbols or mints). If set, bot will only allow trading these.
ALLOWED_TOKENS=BONK,WIF,SAMO